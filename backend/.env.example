# Django Settings
SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DB_NAME=projectouvidoria
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# URL pública do backend (para links de mídia quando o frontend usa outro host/porta)
# Ex.: frontend em localhost:5173 e API em localhost:8000 -> use http://localhost:8000
API_PUBLIC_BASE_URL=

# LLM Configuration (OpenAI, Groq, LocalLLM)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
NLP_ANALYSIS_VERSION=1.0

# Exemplos de configuração:
# Para Groq (Llama 3.3 70B - mais poderoso):
#   OPENAI_API_BASE=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
# Para Groq (Llama 3.1 8B - mais rápido e barato):
#   OPENAI_API_BASE=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.1-8b-instant
# Para LocalLLM: OPENAI_API_BASE=http://localhost:1234/v1
